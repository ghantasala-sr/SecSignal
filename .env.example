# Snowflake connection
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=LAB_WH
SNOWFLAKE_DATABASE=SECSIGNAL
SNOWFLAKE_ROLE=TRAINING_ROLE

# GCS
GCS_BUCKET=secsignal-raw
GCS_PROJECT_ID=your_gcp_project_id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# EDGAR
EDGAR_USER_AGENT=SecSignal your_email@example.com

# API
API_HOST=0.0.0.0
API_PORT=8000

# Access code gate — set to restrict API usage (leave empty to disable)
SECSIGNAL_ACCESS_CODE=your_secret_code

# Cortex AI models
CORTEX_TEXT_EMBED_MODEL=snowflake-arctic-embed-l-v2.0-8k
CORTEX_IMAGE_EMBED_MODEL=voyage-multimodal-3
CORTEX_LLM_MODEL=mistral-large2

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
LOG_LEVEL=INFO
